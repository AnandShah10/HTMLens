{
  "name": "htmlens",
  "displayName": "HTMLens - Universal Template & HTML Previewer",
  "description": "Live preview for HTML, Django templates, Jinja2, Nunjucks and React/JSX components, right inside the editor.",
  "version": "1.0.0",
  "publisher": "local-dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/AnandShah10/HTMLens.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "activationEvents": [
    "onLanguage:html",
    "onLanguage:django-html",
    "onLanguage:jinja",
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "htmlens.open",
        "title": "HTMLens: Open Preview",
        "icon": "$(open-preview)"
      },
      {
        "command": "htmlens.openToSide",
        "title": "HTMLens: Open Preview to the Side",
        "icon": "$(open-preview)"
      },
      {
        "command": "htmlens.toggleElseBranch",
        "title": "HTMLens: Toggle {% if %}/{% else %} Branch"
      },
      {
        "command": "htmlens.refresh",
        "title": "HTMLens: Refresh Preview"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "htmlens.openToSide",
          "when": "editorLangId == html || editorLangId == django-html || editorLangId == jinja || editorLangId == javascriptreact || editorLangId == typescriptreact || resourceExtname == .j2 || resourceExtname == .jinja || resourceExtname == .jinja2 || resourceExtname == .njk",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "htmlens.open"
        },
        {
          "command": "htmlens.openToSide"
        },
        {
          "command": "htmlens.toggleElseBranch"
        },
        {
          "command": "htmlens.refresh"
        }
      ]
    },
    "configuration": {
      "title": "HTMLens",
      "properties": {
        "htmlens.mockVariableStyle": {
          "type": "string",
          "enum": [
            "highlight",
            "value"
          ],
          "default": "highlight",
          "description": "How to render unresolved template variables: highlighted placeholder or a generic mock value."
        },
        "htmlens.includeMaxDepth": {
          "type": "number",
          "default": 5,
          "description": "Max recursion depth when resolving {% extends %} / {% include %}."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.2",
    "typescript": "^5.4.0"
  }
}
